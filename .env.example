# Application
APP_NAME=Adaptive Leveling System
APP_VERSION=0.1.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL/floci)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres

# Cache (Valkey/floci)
REDIS_URL=redis://localhost:6380/0

# Storage (S3/floci)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:4567
S3_BUCKET=ppasq-documents

# LLM Configuration
LLM_PROVIDER=mock
LLM_PRIMARY_MODEL=llama-3.3-70b
LLM_FALLBACK_MODEL=deepseek-r1

# API Keys (configure para providers reais)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Resilience
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT=60

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=adaptive-leveling-system
